# Sentry DSN for the Skyfall Sky demo app.
# Get this from your Sentry project: Settings -> Projects -> [project] -> Client Keys (DSN).
# IMPORTANT: this must be the DSN of the Sentry project that is connected to the Skyfall workspace
# you are using for the demo, otherwise Skyfall will not see the issues this app generates.
VITE_SENTRY_DSN=

# Optional: an environment tag attached to all events captured from this app.
# Useful if you have multiple deploys of this demo and want to filter in Sentry.
VITE_SENTRY_ENVIRONMENT=demo

# Optional: a release identifier so Sentry can correlate issues to a specific build.
# Defaults to "skyfall-sky@dev" if unset.
VITE_SENTRY_RELEASE=
